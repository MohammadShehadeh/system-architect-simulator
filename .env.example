# ---------------------------------------------------------------------------
# Proxmox VE connection — used by the /proxmox live topology viewer.
# These are read server-side only and are NEVER exposed to the browser.
# Copy to .env.local and fill in.
# ---------------------------------------------------------------------------

# Base URL of the Proxmox host, including the API port. "https://" is assumed
# if you omit the protocol.
PROXMOX_HOST=https://pve.example.lan:8006

# API token. Create one under Datacenter → Permissions → API Tokens and grant it
# the read-only PVEAuditor role at path "/". Format: USER@REALM!TOKENID
PROXMOX_TOKEN_ID=monitoring@pve!viewer
PROXMOX_TOKEN_SECRET=00000000-0000-0000-0000-000000000000

# Verify the Proxmox TLS certificate. Set to "false" ONLY for a self-signed
# certificate on a trusted network. Defaults to true (verify).
PROXMOX_TLS_REJECT_UNAUTHORIZED=true

# Optional: server-side cache TTL (ms) for the cheap inventory poll. Default 4000.
PROXMOX_CACHE_TTL_MS=4000
